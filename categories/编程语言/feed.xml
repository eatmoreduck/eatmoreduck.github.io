&lt;/span>&lt;/span>&lt;span class="line">&lt;span class="cl">&lt;span class="nx">Install&lt;/span> &lt;span class="nx">method&lt;/span>&lt;span class="p">:&lt;/span> &lt;span class="nx">npm&lt;/span>
&lt;/span>&lt;/span>&lt;span class="line">&lt;span class="cl">&lt;span class="nx">Requested&lt;/span> &lt;span class="nx">version&lt;/span>&lt;span class="p">:&lt;/span> &lt;span class="nx">latest&lt;/span>
&lt;/span>&lt;/span>&lt;span class="line">&lt;span class="cl">
